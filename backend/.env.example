# Postgres connection string. If you're using Supabase, get this from
# Project Settings -> Database -> Connection string (URI, "Session" mode
# works fine for this app). Prisma needs a direct Postgres connection,
# not the Supabase REST API, so this is different from the old
# VITE_SUPABASE_URL used in the previous Supabase-JS version.
DATABASE_URL="postgresql://postgres:YOUR-PASSWORD@YOUR-HOST:5432/postgres"

# Comma-separated list of origins allowed to call this API (your frontend dev server)
CORS_ORIGINS="http://localhost:5173"
